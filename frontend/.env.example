# ── 本地開發（npm run dev）────────────────────────────────────
# Vite proxy 會自動把 /api、/uploads、/ws 轉到後端
# 所以留空或填 '' 就好，讓請求走相對路徑
VITE_WS_URL=ws://localhost:5173/ws/gps
VITE_API_URL=

# ── 部署時（Cloudflare Tunnel）────────────────────────────────
# VITE_WS_URL=wss://backend.yourdomain.com/ws/gps
# VITE_API_URL=https://backend.yourdomain.com

# 地圖原點 GPS（ENU 座標系統原點）
VITE_ORIGIN_LAT=24.942349
VITE_ORIGIN_LON=121.367164
VITE_ORIGIN_ALT=0

# 場景縮放比例（預設 1）
VITE_SCENE_SCALE=1
